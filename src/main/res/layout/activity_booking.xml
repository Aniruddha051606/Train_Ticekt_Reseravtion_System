<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F6">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_action_bar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="#992200"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <TextView android:id="@+id/lblDep" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEPARTURE" android:textColor="#FFB4A2" android:textSize="10sp" android:textStyle="bold" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
                    <TextView android:id="@+id/tvSource" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NDLS" android:textColor="#FFFFFF" android:textSize="28sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/lblDep" app:layout_constraintStart_toStartOf="parent"/>

                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_media_next" app:tint="#FEA189" app:layout_constraintTop_toTopOf="@id/tvSource" app:layout_constraintBottom_toBottomOf="@id/tvSource" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

                    <TextView android:id="@+id/lblArr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ARRIVAL" android:textColor="#FFB4A2" android:textSize="10sp" android:textStyle="bold" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
                    <TextView android:id="@+id/tvDest" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BSB" android:textColor="#FFFFFF" android:textSize="28sp" android:textStyle="bold" app:layout_constraintTop_toBottomOf="@id/lblArr" app:layout_constraintEnd_toEndOf="parent"/>

                    <View android:id="@+id/divider" android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginTop="20dp" app:layout_constraintTop_toBottomOf="@id/tvSource"/>

                    <TextView android:id="@+id/tvBookingDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Journey Date" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/divider" app:layout_constraintStart_toStartOf="parent"/>
                    <TextView android:id="@+id/tvBookingTrainName" android:layout_width="0dp" android:layout_height="wrap_content" android:text="22436 Vande Bharat" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="16dp" android:layout_marginStart="16dp" android:gravity="end" app:layout_constraintTop_toBottomOf="@id/divider" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toEndOf="@id/tvBookingDate"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="Passenger Details"
                android:textColor="#701600"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E1BFB7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <EditText
                        android:id="@+id/etPassengerName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="#FFF1ED"
                        android:paddingHorizontal="16dp"
                        android:hint="Full Name"
                        android:textColor="#111111"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etPassengerAge"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="#FFF1ED"
                            android:paddingHorizontal="16dp"
                            android:hint="Age"
                            android:inputType="number"
                            android:textColor="#111111"/>

                        <EditText
                            android:id="@+id/etPassengerGender"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:background="#FFF1ED"
                            android:paddingHorizontal="16dp"
                            android:hint="Gender (M/F/O)"
                            android:textColor="#111111"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etContactEmail"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="16dp"
                        android:background="#FFF1ED"
                        android:paddingHorizontal="16dp"
                        android:hint="Email Address"
                        android:inputType="textEmailAddress"
                        android:textColor="#111111"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Base Fare"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvFinalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 0"
                android:textColor="#701600"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnConfirmBooking"
            android:layout_width="160dp"
            android:layout_height="55dp"
            android:backgroundTint="#002068"
            android:text="Proceed"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="12dp" />
    </LinearLayout>
</RelativeLayout>