<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F6"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvCheckoutTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Secure Checkout"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#002068"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvPaymentAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Amount: ₹ 0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#701600"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvCheckoutTitle"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E1BFB7"
        app:layout_constraintTop_toBottomOf="@id/tvPaymentAmount">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Details"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="#FFF1ED"
                android:paddingHorizontal="16dp"
                android:hint="Card Number (4111 2222 3333 4444)"
                android:inputType="number"
                android:textColor="#111111"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="#FFF1ED"
                    android:paddingHorizontal="16dp"
                    android:hint="MM/YY"
                    android:textColor="#111111"/>

                <EditText
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="#FFF1ED"
                    android:paddingHorizontal="16dp"
                    android:hint="CVV"
                    android:inputType="numberPassword"
                    android:maxLength="3"
                    android:textColor="#111111"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnPayNow"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Pay Securely"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                android:backgroundTint="#002068"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 Encrypted by IRCTC Gateway"
                android:textAlignment="center"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>